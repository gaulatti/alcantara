# Copy to .env and fill values
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alcantara?schema=public"
ALLOWED_ORIGINS="http://localhost:5173,https://alcantara.gaulatti.com"
PORT=3000
AWS_REGION=us-east-1

# Required for Cognito JWT validation
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional media uploads (instants/artwork) to S3
MEDIA_S3_BUCKET="your-bucket-name"
