// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Layout {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  componentType  String
  settings       String   // JSON stringified
  scenes         Scene[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Scene {
  id            Int            @id @default(autoincrement())
  name          String
  layoutId      Int
  layout        Layout         @relation(fields: [layoutId], references: [id])
  chyronText    String?
  metadata      String?        // JSON stringified
  programStates ProgramState[]
  programScenes ProgramScene[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProgramState {
  id            Int            @id @default(autoincrement())
  programId     String         @unique
  activeSceneId Int?
  activeScene   Scene?         @relation(fields: [activeSceneId], references: [id])
  scenes        ProgramScene[]
  updatedAt     DateTime       @updatedAt
}

model ProgramScene {
  id             Int          @id @default(autoincrement())
  programStateId Int
  sceneId        Int
  position       Int
  programState   ProgramState @relation(fields: [programStateId], references: [id], onDelete: Cascade)
  scene          Scene        @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([programStateId, sceneId])
  @@unique([programStateId, position])
}

model BroadcastSettings {
  id                    Int      @id
  timeOverrideEnabled   Boolean  @default(false)
  timeOverrideStartTime String?
  timeOverrideStartedAt DateTime?
  updatedAt             DateTime @updatedAt
}

model FifthBellSettings {
  id                Int      @id
  showArticles      Boolean  @default(true)
  showWeather       Boolean  @default(true)
  showEarthquakes   Boolean  @default(true)
  showMarkets       Boolean  @default(true)
  showMarquee       Boolean  @default(false)
  showCallsignTake  Boolean  @default(true)
  weatherCitiesJson String   @default("[]")
  updatedAt         DateTime @updatedAt
}
