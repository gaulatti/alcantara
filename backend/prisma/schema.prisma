// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Layout {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  componentType  String
  settings       String   // JSON stringified
  scenes         Scene[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Scene {
  id            Int            @id @default(autoincrement())
  name          String
  layoutId      Int
  layout        Layout         @relation(fields: [layoutId], references: [id])
  chyronText    String?
  metadata      String?        // JSON stringified
  programStates ProgramState[]
  programScenes ProgramScene[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ProgramState {
  id            Int            @id @default(autoincrement())
  programId     String         @unique
  activeSceneId Int?
  activeScene   Scene?         @relation(fields: [activeSceneId], references: [id])
  songSequence  Json?
  scenes        ProgramScene[]
  updatedAt     DateTime       @updatedAt
}

model ProgramScene {
  id             Int          @id @default(autoincrement())
  programStateId Int
  sceneId        Int
  position       Int
  programState   ProgramState @relation(fields: [programStateId], references: [id], onDelete: Cascade)
  scene          Scene        @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([programStateId, sceneId])
  @@unique([programStateId, position])
}

model BroadcastSettings {
  id                    Int      @id
  timeOverrideEnabled   Boolean  @default(false)
  timeOverrideStartTime String?
  timeOverrideStartedAt DateTime?
  mainMasterVolume      Float    @default(1)
  songMasterVolume      Float    @default(1)
  instantMasterVolume   Float    @default(1)
  songMuted             Boolean  @default(false)
  instantMuted          Boolean  @default(false)
  songSolo              Boolean  @default(false)
  instantSolo           Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

model Instant {
  id        Int      @id @default(autoincrement())
  name      String
  audioUrl  String
  volume    Float    @default(1)
  enabled   Boolean  @default(true)
  position  Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Song {
  id           Int      @id @default(autoincrement())
  artist       String
  title        String
  audioUrl     String
  coverUrl     String?
  durationMs   Int?
  earoneSongId String?
  earoneRank   String?
  earoneSpins  String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
